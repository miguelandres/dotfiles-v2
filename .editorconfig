root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.sh]
shell_variant = zsh
switch_case_indent = true
space_redirects = true

[zsh/**]
shell_variant = zsh
switch_case_indent = true
space_redirects = true

[{zshrc,zshenv,*.zsh}]
shell_variant = zsh
switch_case_indent = true
space_redirects = true
