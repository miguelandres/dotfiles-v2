# shellcheck shell=bash

HOMEBREW_FORCE_VENDOR_RUBY=1
export HOMEBREW_FORCE_VENDOR_RUBY

if [ -d "/opt/homebrew/opt" ]
then
  # shellcheck disable=SC2046
  eval $(/opt/homebrew/bin/brew shellenv)
else
  # shellcheck disable=SC2046
  eval $(/usr/local/bin/brew shellenv)
fi

BREW_PREFIX=$(brew --prefix)
PATH=$BREW_PREFIX/opt/ruby/bin:$BREW_PREFIX/opt/openssl@3/bin:$BREW_PREFIX/opt/python3/libexec/bin/:$PATH

PATH="$HOME/.jenv/bin:$PATH"
eval "$(jenv init -)"
PATH=$(gem environment gemdir 2>/dev/null)/bin:$PATH
ANDROID_SDK_ROOT=$BREW_PREFIX/share/android-commandlinetools
SCALA_HOME=$BREW_PREFIX/opt/scala/idea
export PATH
export ANDROID_SDK_ROOT
export SCALA_HOME

# shellcheck disable=SC1091
source "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
ZSH_HIGHLIGHT_HIGHLIGHTERS_DIR="$(brew --prefix)/share/zsh-syntax-highlighting/highlighters"
export ZSH_HIGHLIGHT_HIGHLIGHTERS_DIR
# Load Angular CLI autocompletion.
source <(ng completion script)

# Load jj autocompletions
source <(COMPLETE=zsh jj)

# Zsh keybindings for macOS (Terminal.app, iTerm2, etc.)
# --------------------------------------------------------

# 1. Option / Ctrl + Left/Right Arrow keys -> Move cursor word-by-word
bindkey "\e[1;3D" backward-word
bindkey "\e[1;3C" forward-word
bindkey "\e[1;5D" backward-word
bindkey "\e[1;5C" forward-word
bindkey "\e[1;9D" backward-word
bindkey "\e[1;9C" forward-word
bindkey "\e[1;10D" backward-word
bindkey "\e[1;10C" forward-word
bindkey "\e[5D" backward-word
bindkey "\e[5C" forward-word
bindkey "\e\e[D" backward-word
bindkey "\e\e[C" forward-word
bindkey "\eb" backward-word
bindkey "\ef" forward-word

# 2. Command + Left/Right Arrow keys (and Home/End keys) -> Move cursor to beginning/end of line
bindkey "\e[H" beginning-of-line
bindkey "\e[F" end-of-line
bindkey "\eOH" beginning-of-line
bindkey "\eOF" end-of-line
bindkey "\e[1~" beginning-of-line
bindkey "\e[4~" end-of-line
bindkey "\e[1;2D" beginning-of-line
bindkey "\e[1;2C" end-of-line
bindkey "\e[1;8D" beginning-of-line
bindkey "\e[1;8C" end-of-line

